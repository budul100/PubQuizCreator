@using PubQuizCreator.Core.Models

<div class="d-flex flex-wrap gap-1 @CssClass">
    @foreach (var cs in CategoryStats)
    {
        var catColor = cs.Category?.ColorHex ?? "#95a5a6";
        var badgeStyle = cs.Open == 0 ? "opacity: 0.45;" : "";

        <CategoryBadge ColorHex="@catColor"
                       Name="@(cs.Category?.Name ?? "")"
                       CssClass="d-inline-flex align-items-center gap-1"
                       Style="@badgeStyle">
            <span class="fw-bold">@cs.Open/@cs.Total</span>
        </CategoryBadge>
    }
</div>

@code {
    [Parameter] public IEnumerable<SlotCategoryStat> CategoryStats { get; set; } = [];
    [Parameter] public string CssClass { get; set; } = "";

    public record SlotCategoryStat(Category? Category, int Open, int Total);
}
