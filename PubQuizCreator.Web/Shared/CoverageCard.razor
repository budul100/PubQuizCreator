@inject DashboardService DashboardService

<div class="card">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        <span>Slot coverage</span>
        @if (isLoading)
        {
            <span class="spinner-border spinner-border-sm text-secondary" />
        }
    </div>
    <div class="card-body p-2">
        @if (!isLoading && coverage.Count == 0)
        {
            <p class="text-muted small mb-0">No upcoming quizzes with open slots.</p>
        }
        else
        {
            @foreach (var item in coverage)
            {
                var color = item.Category.ColorHex;
                var textColor = color.TextColor();
                var badgeStyle = item.IsCovered
                ? $"background-color: {color}; color: {textColor}; opacity: 0.35;"
                : $"background-color: {color}; color: {textColor};";
                var badgeClass = "badge d-flex align-items-center justify-content-between gap-2 w-100";
                var countContent = item.IsCovered
                ? $"{item.AvailableQuestions}/{item.TotalOpenSlots} ✓"
                : $"{item.AvailableQuestions}/{item.TotalOpenSlots} (−{item.Deficit})";
                var countClass = !item.IsCovered ? "fw-bold text-nowrap" : "fw-normal text-nowrap";

                <div class="mb-2">
                    @if (NavigateToQuestions)
                    {
                        <a href="/questions?categoryId=@item.Category.Id&showUsed=false"
                           class="@badgeClass text-decoration-none"
                           style="@badgeStyle cursor: pointer;">
                            <span class="text-truncate">@item.Category.Name</span>
                            <span class="@countClass" style="opacity: 1;">@countContent</span>
                        </a>
                    }
                    else if (OnCategorySelected.HasDelegate)
                    {
                        <span class="@badgeClass"
                              style="@badgeStyle cursor: pointer;"
                              @onclick="() => OnCategorySelected.InvokeAsync(item.Category.Id)">
                            <span class="text-truncate">@item.Category.Name</span>
                            <span class="@countClass" style="opacity: 1;">@countContent</span>
                        </span>
                    }
                    else
                    {
                        <span class="@badgeClass" style="@badgeStyle">
                            <span class="text-truncate">@item.Category.Name</span>
                            <span class="@countClass" style="opacity: 1;">@countContent</span>
                        </span>
                    }
                </div>
            }
        }
    </div>
</div>
