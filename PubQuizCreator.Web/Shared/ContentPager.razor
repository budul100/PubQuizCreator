<!-- Renders pagination controls. Resets to page 1 on filter changes via CurrentPage binding. -->

<nav aria-label="Pagination" class="d-flex align-items-center gap-2 mt-2">
    <button class="btn btn-outline-secondary btn-sm"
        disabled="@(CurrentPage <= 1)"
        @onclick="() => PageChanged.InvokeAsync(CurrentPage - 1)">‹</button>

    @for (int i = StartPage; i <= EndPage; i++)
    {
        var page = i;
        var btnClass = page == CurrentPage ? "btn btn-sm btn-primary" : "btn btn-sm btn-outline-secondary";
        <button class="@btnClass" @onclick="() => PageChanged.InvokeAsync(page)">
            @(page)
        </button>
    }

    <button class="btn btn-outline-secondary btn-sm"
            disabled="@(CurrentPage >= TotalPages)"
            @onclick="() => PageChanged.InvokeAsync(CurrentPage + 1)">›</button>

    <span class="text-muted small ms-1">@TotalItems items</span>
</nav>
