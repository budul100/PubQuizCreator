<div class="card">
    <div class="card-header d-flex align-items-center gap-2 fw-semibold">
        Similar questions
        @if (IsSearching)
        {
            <span class="spinner-border spinner-border-sm text-secondary" />
        }
    </div>
    <div class="card-body p-2">
        @if (!Similars.Any())
        {
            <p class="text-muted small mb-0">
                @(HasSearched ? "No similar questions found." : "Start typing to search for duplicates.")
            </p>
        }
        else
        {
            var visibleSimilar = Similars
            .Where(sq => sq.Distance < Constants.SimilarityThresholdMedium)
            .ToList();

            @if (!visibleSimilar.Any())
            {
                <p class="text-muted small mb-0">
                    @(HasSearched ? "No similar questions found." : "Start typing to search for duplicates.")
                </p>
            }
            else
            {
                @foreach (var sq in visibleSimilar)
                {
                    var borderClass = sq.Distance < Constants.SimilarityThresholdHigh ? "border-danger" : "border-warning";
                    var badgeClass = sq.Distance < Constants.SimilarityThresholdHigh ? "bg-danger" : "bg-warning text-dark";
                    var label = sq.Distance < Constants.SimilarityThresholdHigh ? "very similar" : "similar";

                    <div class="border rounded p-2 mb-2 @borderClass">
                        <div class="small fw-semibold">@sq.TextShort</div>
                        <div class="small text-muted">→ @sq.Answer</div>
                        <div class="text-end mt-1">
                            <span class="badge @badgeClass">@label</span>
                        </div>
                    </div>
                }
            }
        }
    </div>
</div>
