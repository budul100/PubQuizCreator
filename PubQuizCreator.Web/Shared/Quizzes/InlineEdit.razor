@if (IsEditing)
{
    <div class="d-flex align-items-center gap-2" @onclick:stopPropagation="true">
        <UnidirectionalInput 
            style="@InputStyle"
            CssClass="form-control form-control-sm"
            Placeholder="@Placeholder"
            Value="@currentValue"
            ValueChanged="txt => currentValue = txt"
            OnInputBlur="HandleBlur"
            OnKeyDown="HandleKeyDown" />

        @if (ShowButtons)
        {
            <button class="btn btn-success btn-sm text-nowrap" @onclick="ConfirmAsync">
                @ConfirmLabel
            </button>
            <button class="btn btn-outline-secondary btn-sm text-nowrap" @onclick="CancelAsync">
                Cancel
            </button>
        }
    </div>
}
else
{
    <span style="cursor: text; @LabelStyle" @onclick="StartEditing">
        @(string.IsNullOrWhiteSpace(displayValue) ? Placeholder : displayValue)
    </span>
}