@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="" @onclick="OnHomeClickAsync">Pub Quiz Creator</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/ideas" Match="NavLinkMatch.Prefix">
                <span class="oi oi-lightbulb" aria-hidden="true"></span> Ideas
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/questions" Match="NavLinkMatch.Prefix">
                <span class="oi oi-question-mark" aria-hidden="true"></span> Questions
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/quizzes" Match="NavLinkMatch.Prefix">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Quizzes
            </NavLink>
        </div>

        <hr style="border-color: rgba(255,255,255,0.15); margin: 0.5rem 1rem;" />
        <div class="px-3 pb-1" style="color: rgba(255,255,255,0.4); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">
            Options
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/categories" Match="NavLinkMatch.Prefix">
                <span class="oi oi-tag" aria-hidden="true"></span> Categories
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/templates" Match="NavLinkMatch.Prefix">
                <span class="oi oi-grid-three-up" aria-hidden="true"></span> Templates
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/settings" Match="NavLinkMatch.Prefix">
                <span class="oi oi-cog" aria-hidden="true"></span> Settings
            </NavLink>
        </div>

        <hr style="border-color: rgba(255,255,255,0.15); margin: 0.5rem 1rem;" />

        <div class="nav-item px-3">
            <a class="nav-link" href="/logout">
                <span class="oi oi-account-logout" aria-hidden="true"></span> Sign out
            </a>
        </div>

    </nav>

    <div class="version-info">
        Version @AppVersion
    </div>

</div>