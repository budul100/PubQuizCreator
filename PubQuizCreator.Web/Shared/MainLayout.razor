@inherits LayoutComponentBase
@inject DashboardService DashboardService
@inject StateService StateService
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <span class="fw-semibold text-secondary">@StateService.PageTitle</span>
            <div class="d-flex gap-2 align-items-center">
                @if (missingQuestions > 0)
                {
                    <span class="badge bg-warning text-dark">@missingQuestions missing questions</span>
                }
                else
                {
                    <span class="badge bg-success">All slots covered</span>
                }
                <span class="badge @(StateService.OllamaOnline ? "bg-success" : "bg-danger")">
                    Ollama @(StateService.OllamaOnline ? "online" : "offline")
                </span>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

