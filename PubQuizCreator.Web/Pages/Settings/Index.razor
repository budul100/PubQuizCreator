@page "/settings"
@using PubQuizCreator.Services.App
@using PubQuizCreator.Services.Content
@inject SettingsService SettingsService
@inject StateService AppState
@inject IJSRuntime JS

<PageTitle>Settings</PageTitle>

<PageHeader Title="Settings" />

@if (settings == null)
{
    <p class="text-muted">Loading…</p>
}
else
{
    @* Device *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Device</div>
        <div class="card-body">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="autoOpenCapture"
                       @bind="autoOpenCapture"
                       @bind:after="SaveAutoOpenCaptureAsync" />
                <label class="form-check-label" for="autoOpenCapture">
                    Open capture page on startup
                </label>
            </div>
        </div>
    </div>

    @* Quiz *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Quiz</div>
        <div class="card-body d-flex flex-column gap-2">
            <div>
                <label class="form-label mb-1">TextShort Warn Length</label>
                <input class="form-control" type="number" @bind="settings.TextShortWarnLength" />
            </div>
            <div>
                <label class="form-label mb-1">AI check URL</label>
                <input class="form-control" @bind="settings.AiUrl" />
            </div>
            <div>
                <label class="form-label mb-1">AI Check Prompt</label>
                <textarea class="form-control font-monospace" rows="8" @bind="settings.AiPrompt" />
                <div class="form-text">Available placeholders: <code>{question}</code>, <code>{answer}</code></div>
            </div>
        </div>
    </div>

    @* Print *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Print</div>
        <div class="card-body d-flex flex-column gap-2">
            <div>
                <label class="form-label mb-1">Default Font Size</label>
                <input class="form-control" type="number" step="0.5" @bind="settings.PrintFontSizeDefault" />
            </div>
            <div>
                <label class="form-label mb-1">Header Font Size</label>
                <input class="form-control" type="number" step="0.5" @bind="settings.PrintFontSizeHeader" />
            </div>
        </div>
    </div>

    @* Export *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Export</div>
        <div class="card-body d-flex flex-column gap-3">

            <div>
                <label class="form-label mb-1">Slide Title Format</label>
                <input class="form-control" @bind="settings.TitleFormat" />
                <div class="form-text">Available placeholders: <code>{position}</code></div>
            </div>

            <div>
                <label class="form-label mb-1">PPTX Templates</label>

                @if (settings.PptxTemplates.Count == 0)
                {
                    <p class="text-muted small mb-1">No templates uploaded yet.</p>
                }
                else
                {
                    @foreach (var fileName in settings.PptxTemplates)
                    {
                        var name = fileName;
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="font-monospace text-truncate flex-grow-1">@name</span>
                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => RemoveTemplate(name)">
                                <span class="oi oi-trash" />
                            </button>
                        </div>
                    }
                }

                <div>
                    <label class="btn btn-outline-secondary btn-sm mb-0" style="cursor:pointer;">
                        + Upload template
                        <InputFile OnChange="UploadTemplateAsync" accept=".pptx,.potx"
                                   style="display:none;" />
                    </label>
                </div>
                <div class="form-text">
                    Each uploaded file appears as a selectable template when exporting a round.
                </div>
            </div>
        </div>
    </div>

    @* Save *@
    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@saving">
            @(saving ? "Saving…" : "Save")
        </button>
        @if (savedAt != null)
        {
            <span class="text-success small">Saved at @savedAt.Value.ToString("HH:mm:ss")</span>
        }
        @if (saveError != null)
        {
            <span class="text-danger small">@saveError</span>
        }
    </div>
}