@page "/settings"
@using PubQuizCreator.Services
@inject SettingsService SettingsService
@inject StateService AppState

<PageTitle>Settings</PageTitle>

<PageHeader Title="Settings" />

@if (settings == null)
{
    <p class="text-muted">Loading…</p>
}
else
{    
    @* Quiz *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Quiz</div>
        <div class="card-body d-flex flex-column gap-2">
            <div>
                <label class="form-label mb-1">TextShort Warn Length</label>
                <input class="form-control" type="number" @bind="settings.TextShortWarnLength" />
            </div>
            <div>
                <label class="form-label mb-1">AI check URL</label>
                <input class="form-control" @bind="settings.AiUrl" />
            </div>
            <div>
                <label class="form-label mb-1">AI Check Prompt</label>
                <textarea class="form-control font-monospace" rows="8" @bind="settings.AiPrompt" />
                <div class="form-text">Available placeholders: <code>{question}</code>, <code>{answer}</code></div>
            </div>
        </div>
    </div>

    @* Print *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Print</div>
        <div class="card-body d-flex flex-column gap-2">
            <div>
                <label class="form-label mb-1">Default Font Size</label>
                <input class="form-control" type="number" step="0.5" @bind="settings.PrintFontSizeDefault" />
            </div>
            <div>
                <label class="form-label mb-1">Header Font Size</label>
                <input class="form-control" type="number" step="0.5" @bind="settings.PrintFontSizeHeader" />
            </div>
        </div>
    </div>
    
    @* Export *@
    <div class="card mb-3">
        <div class="card-header fw-semibold">Export</div>
        <div class="card-body d-flex flex-column gap-3">

            <div>
                <label class="form-label mb-1">Questions Template File</label>
                <div class="d-flex align-items-center gap-2">
                    <span class="font-monospace text-truncate flex-grow-1">
                        @(string.IsNullOrEmpty(settings.TemplateQuestions)
                            ? "— no file —"
                            : settings.TemplateQuestions)
                    </span>
                    <label class="btn btn-outline-secondary btn-sm mb-0 text-nowrap" style="cursor:pointer;">
                        @(string.IsNullOrEmpty(settings.TemplateQuestions) ? "Upload" : "Replace")
                        <InputFile OnChange="e => UploadTemplateAsync(e, TemplateRole.Questions)"
                            accept=".pptx,.potx"
                            style="display:none;" />
                    </label>
                </div>
            </div>

            <div>
                <label class="form-label mb-1">Answers Template File</label>
                <div class="d-flex align-items-center gap-2">
                    <span class="font-monospace text-truncate flex-grow-1">
                        @(string.IsNullOrEmpty(settings.TemplateAnswers)
                            ? "— no file —"
                            : settings.TemplateAnswers)
                    </span>
                    <label class="btn btn-outline-secondary btn-sm mb-0 text-nowrap" style="cursor:pointer;">
                        @(string.IsNullOrEmpty(settings.TemplateAnswers) ? "Upload" : "Replace")
                        <InputFile OnChange="e => UploadTemplateAsync(e, TemplateRole.Answers)"
                            accept=".pptx,.potx"
                            style="display:none;" />
                </label>
            </div>
        </div>

            <hr class="my-1" />

            <label class="form-label mb-1">Additional Export Files</label>

        @for (var i = 0; i < settings.AdditionalFiles.Count; i++)
            {
                var index = i;
                <div class="d-flex align-items-center gap-2">
                    <span class="font-monospace text-truncate flex-grow-1">
                        @settings.AdditionalFiles[index]
                    </span>
                    <label class="btn btn-outline-secondary btn-sm mb-0 text-nowrap" style="cursor:pointer;">
                        Replace
                        <InputFile OnChange="e => ReplaceAdditionalFileAsync(e, index)"
                                   style="display:none;" />
                    </label>
                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => settings.AdditionalFiles.RemoveAt(index)">
                        ✕
                    </button>
                </div>
            }

            <div>
                <label class="btn btn-outline-secondary btn-sm mb-0" style="cursor:pointer;">
                    + Add file
                    <InputFile OnChange="AddAdditionalFileAsync" style="display:none;" />
                </label>
            </div>

            <div class="form-text">
                Files are saved immediately on upload. Included in every quiz export as
                <code>quiz_yyyy-MM-dd_filename</code>.
            </div>

        </div>
    </div>

    @* Save *@
    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@saving">
            @(saving ? "Saving…" : "Save")
        </button>
        @if (savedAt != null)
        {
            <span class="text-success small">Saved at @savedAt.Value.ToString("HH:mm:ss")</span>
        }
        @if (saveError != null)
        {
            <span class="text-danger small">@saveError</span>
        }
    </div>
}
