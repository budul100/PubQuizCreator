@page "/quizzes/{Id:guid}"
@using PubQuizCreator.Core
@using PubQuizCreator.Core.Models
@using PubQuizCreator.Core.Types 
@using PubQuizCreator.Services
@inject QuizService QuizService
@inject TemplateService TemplateService
@inject CategoryService CategoryService
@inject QuestionService QuestionService
@inject StateService AppState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(quiz?.Title ?? "Quiz")</PageTitle>

@if (quiz == null)
{
    <p class="text-muted">Loading…</p>
}
else
{
    @* Header row: Title + Date + Export buttons *@
    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
        <input class="form-control"
               style="min-width: 0; flex: 1 1 180px; max-width: 400px;"
               value="@quiz.Title"
               @onchange="e => quiz.Title = e.Value?.ToString() ?? string.Empty"
               @onblur="SaveHeaderAsync" />
        <input type="date"
               class="form-control"
               style="width: auto; flex-shrink: 0;"
               value="@quiz.Date.ToString("yyyy-MM-dd")"
               @onchange="e => { quiz.Date = DateOnly.Parse(e.Value?.ToString() ?? string.Empty); _ = SaveHeaderAsync(); }" />
        <button class="btn btn-sm @(quiz.IsCompleted ? "btn-success" : "btn-outline-secondary")"
                @onclick="ToggleCompletedAsync">
            @(quiz.IsCompleted ? "✓ Completed" : "Mark as completed")
        </button>
        <div class="d-flex gap-2 ms-auto flex-shrink-0">
            <a class="btn btn-outline-secondary btn-sm" href="/export/quiz/@quiz.Id/pdf" target="_blank">⬇ PDF</a>
            <a class="btn btn-outline-secondary btn-sm" href="/export/quiz/@quiz.Id/pptx" target="_blank">⬇ PPTX</a>
        </div>
    </div>

    @* Rounds *@
    @foreach (var round in quiz.Rounds.OrderBy(r => r.Position))
    {
        var r = round;

        var totalSlots = r.Slots.Count;
        var openSlots = r.Slots.Count(s => s.QuestionId == null);

        <div class="card mb-3"
             draggable="true"
             @ondragstart="() => dragFromRound = r.Id"
             @ondragover="_ => { }"
             @ondragover:preventDefault="true"
             @ondrop="() => DropRound(r.Id)">

            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2"
                 style="cursor: pointer;"
                 @onclick="() => ToggleRound(r.Id)">

                <span>
                    <span class="me-2 text-muted">☰</span>
                    <strong>Round @r.Position</strong>
                    <span class="text-muted me-2">@(AppState.RoundsCollapsed.Contains(r.Id) ? "▶" : "▼")</span>
                    <SlotBadge Open="openSlots" Total="totalSlots" CssClass="ms-2" />
                </span>

                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                    @if (r.Slots.All(s => s.QuestionId == null))
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveRoundAsync(r.Id)">
                            <span class="oi oi-trash" />
                        </button>
                    }
                </div>
            </div>

            @if (!AppState.RoundsCollapsed.Contains(r.Id))
            {
                <div class="list-group list-group-flush">

                @if (addSlotRound?.Id == r.Id && addSlotAfterPosition == 0)
                {
                    <CategorySelector Categories="categories"
                        @bind-SelectedCategoryId="addSlotCategoryId"
                        OnConfirm="ConfirmAddSlotAsync"
                        OnCancel="() => addSlotRound = null" />
                }

                @foreach (var slot in r.Slots.OrderBy(s => s.Position))
                    {
                        var s = slot;
                        var editUrl = s.Question != null
                            ? $"/questions/{s.Question.Id}/edit?returnUrl=/quizzes/{Id}"
                            : null;

                        <div class="list-group-item py-2"
                             draggable="true"
                             @ondragstart="() => { dragFromSlot = s.Id; dragFromSlotRound = r.Id; }"
                             @ondragover="_ => { }"
                             @ondragover:preventDefault="true"
                             @ondrop="() => DropSlot(r.Id, s.Id)"
                             style="cursor: grab;">

                            @* Top row: handle + position + category + buttons *@
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="text-muted flex-shrink-0">☰</span>
                                <span class="badge bg-light text-secondary border flex-shrink-0"
                                      style="min-width: 1.8rem; text-align: center; font-weight: 600;">
                                    @s.Position
                                </span>
                                
                                @{
                                    var catColor = s.Category?.ColorHex ?? "#95a5a6";
                                    var catCss = "text-truncate d-inline-block" + (s.Question == null ? " cursor-pointer" : "");
                                    var catStyle = "flex: 1; min-width: 0; cursor: " + (s.Question == null ? "pointer" : "default") + ";";
                                }

                                @if (editCategorySlot?.Id == s.Id)
                                {
                                    <CategorySelector Categories="categories"
                                        @bind-SelectedCategoryId="editCategorySlotCategoryId"
                                        ConfirmLabel="Save"
                                        OnConfirm="() => SaveCategoryAsync(s.Id)"
                                        OnCancel="() => editCategorySlot = null" />
                                }
                                else
                                {
                                    <div style="@catStyle"
                                        @onclick="@(s.Question == null ? EventCallback.Factory.Create(this, () => { editCategorySlot = s; editCategorySlotCategoryId = s.CategoryId; }) : default)"
                                        @onclick:stopPropagation="true">
                                        <CategoryBadge ColorHex="@catColor" Name="@(s.Category?.Name ?? "— no category —")"
                                            CssClass="@catCss"
                                            Style="max-width: 100%;" />
                                    </div>
                                }
                
                                <div class="d-flex gap-1 flex-shrink-0" @onclick:stopPropagation="true">

                                    @if (s.Question != null)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm"
                                                title="Reassign"
                                                @onclick="async () => await OpenPickerAsync(s)"
                                                @onclick:stopPropagation="true">
                                            <span class="oi oi-pencil" />
                                        </button>
                                        <button class="btn btn-warning btn-sm"
                                                title="Unassign"
                                                @onclick="() => UnassignAsync(s.Id)">
                                            <span class="oi oi-action-undo" />
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-danger btn-sm"
                                                title="Remove slot"
                                                @onclick="() => RemoveSlotAsync(s.Id)">
                                            <span class="oi oi-trash" />
                                        </button>
                                    }

                                    <button class="btn btn-outline-secondary btn-sm"
                                            title="Insert slot above"
                                            @onclick="() => OpenAddSlot(r, s.Position - 1)">
                                        <span class="oi oi-arrow-top" />
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm"
                                            title="Insert slot below"
                                            @onclick="() => OpenAddSlot(r, s.Position)">
                                        <span class="oi oi-arrow-bottom" />
                                    </button>

                                </div>
                            </div>

                            @* Question + Answer — klickbar für Picker/Edit *@
                            <div style="padding-left: 2.8rem; cursor: pointer;"
                                 @onclick="async () => { if (editUrl != null) Nav.NavigateTo(editUrl); else await OpenPickerAsync(s); }"
                                 @onclick:stopPropagation="true">
                                <div class="small fw-semibold @(s.Question == null ? "text-muted fst-italic" : "")">
                                    @(s.Question?.TextShort ?? "— click to assign —")
                                    @if (s.Question?.MediaType is { } mt && mt != MediaType.None)
                                    {
                                        var icon = mt switch
                                        {
                                            MediaType.Image => "🖼",
                                            MediaType.Audio => "🎵",
                                            MediaType.Video => "🎬",
                                            _ => ""
                                        };
                                        <span class="ms-1 text-muted">| @icon</span>
                                    }
                                </div>
                                @if (s.Question != null)
                                {
                                    <div class="small text-muted">→ @s.Question.Answer</div>
                                }
                            </div>

                        </div>

                        @if (pickerSlot?.Id == s.Id)
                        {
                            <div class="list-group-item p-2 border-top bg-light">

                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-semibold small">Assign question — @pickerSlot.Category?.Name</span>
                                    <button class="btn-close btn-sm" @onclick="() => pickerSlot = null" />
                                </div>

                                <SearchInput @ref="pickerSearchInput"
                                             @bind-Value="pickerSearch"
                                             @bind-Value:after="ApplySearch" />

                                <div class="small text-muted mb-2">
                                    @pickerFiltered.Count of @pickerAll.Count in this category
                                </div>
                                
                                <div class="list-group">
                                    @foreach (var picker in pickerFiltered.Take(Constants.PageSizePicker))
                                    {
                                        <button class="list-group-item list-group-item-action py-1"
                                                @onclick="() => AssignAsync(picker.Id)">
                                            <div class="small fw-semibold">
                                                @picker.TextShort
                                                @if (picker?.MediaType is { } mts && mts != MediaType.None)
                                                {
                                                    var icon = mts switch
                                                    {
                                                        MediaType.Image => "🖼",
                                                        MediaType.Audio => "🎵",
                                                        MediaType.Video => "🎬",
                                                        _ => ""
                                                    };
                                                    <span class="small text-muted fs-4" title="@mts.ToString()"> | @icon</span>
                                                }
                                            </div>
                                            <div class="small text-muted">→ @picker?.Answer</div>
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @if (addSlotRound?.Id == r.Id && addSlotAfterPosition == s.Position)
                        {
                            <CategorySelector Categories="categories"
                                @bind-SelectedCategoryId="addSlotCategoryId"
                                OnConfirm="ConfirmAddSlotAsync"
                                OnCancel="() => addSlotRound = null" />
                        }
                    }
                </div>
            }
        </div>
    }

    @* Add round controls *@
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <button class="btn btn-outline-secondary btn-sm"
                @onclick="AddEmptyRoundAsync">
            + Empty round
        </button>
        <button class="btn btn-outline-primary btn-sm"
                @onclick="() => showTemplatePicker = true">
            + Round from template
        </button>
    </div>

    @if (showTemplatePicker)
    {
        <div class="card border-primary mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Add round from template</strong>
                <button class="btn-close" @onclick="() => showTemplatePicker = false" />
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <select class="form-select" @bind="selectedTemplateId">
                    <option value="@Guid.Empty">— select template —</option>
                    @foreach (var t in templates)
                    {
                        <option value="@t.Id">@t.Name (@t.Slots.Count slots)</option>
                    }
                </select>
                <button class="btn btn-primary btn-sm"
                        @onclick="AddRoundFromTemplateAsync"
                        disabled="@(selectedTemplateId == Guid.Empty)">
                    Add round
                </button>
            </div>
        </div>
    }
}
