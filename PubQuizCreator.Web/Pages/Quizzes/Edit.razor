@page "/quizzes/{Id:guid}"
@using PubQuizCreator.Core
@using PubQuizCreator.Core.Models
@using PubQuizCreator.Core.Types 
@using PubQuizCreator.Services
@inject QuizService QuizService
@inject TemplateService TemplateService
@inject CategoryService CategoryService
@inject QuestionService QuestionService
@inject StateService AppState
@inject NavigationManager Nav

<PageTitle>@(quiz?.Title ?? "Quiz")</PageTitle>

@if (quiz == null)
{
    <p class="text-muted">Loading…</p>
}
else
{
    @* Header row: Title + Date + Export buttons *@
    <div class="d-flex align-items-center gap-2 mb-2">
        <input class="form-control"
               style="min-width: 260px; max-width: 400px;"
               value="@quiz.Title"
               @onchange="e => quiz.Title = e.Value?.ToString() ?? string.Empty"
               @onblur="SaveHeaderAsync" />
        <input type="date"
               class="form-control w-auto"
               value="@quiz.Date.ToString("yyyy-MM-dd")"
               @onchange="e => { quiz.Date = DateOnly.Parse(e.Value?.ToString() ?? string.Empty); _ = SaveHeaderAsync(); }" />
        <button class="btn btn-sm @(quiz.IsCompleted ? "btn-success" : "btn-outline-secondary")"
                title="@(quiz.IsCompleted ? "Mark as active" : "Mark as completed")"
                @onclick="ToggleCompletedAsync">
            @(quiz.IsCompleted ? "✓ Completed" : "Mark as completed")
        </button>

        <div class="ms-auto d-flex gap-2">
            <a class="btn btn-outline-secondary btn-sm"
               href="/export/quiz/@quiz.Id/pdf"
               target="_blank">
                ⬇ PDF
            </a>
            <a class="btn btn-outline-secondary btn-sm"
               href="/export/quiz/@quiz.Id/pptx"
               target="_blank">
                ⬇ PPTX
            </a>
        </div>
    </div>

    @* Rounds *@
    @foreach (var round in quiz.Rounds.OrderBy(r => r.Position))
    {
        var r = round;
        var openInRound = r.Slots.Count(s => s.QuestionId == null);
        var (roundLabel, roundBadge) = r.Slots.Count == 0
            ? ("Empty", "bg-secondary")
            : openInRound == 0
                ? ("✓", "bg-success")
                : ($"{openInRound} open", "bg-warning text-dark");

        <div class="card mb-3"
             draggable="true"
             @ondragstart="() => dragFromRound = r.Id"
             @ondragover="OnDragOver"
             @ondragover:preventDefault="true"
             @ondrop="() => DropRound(r.Id)">

            <div class="card-header d-flex justify-content-between align-items-center"
                 style="cursor: pointer;"
                 @onclick="() => ToggleRound(r.Id)"
                 @onclick:stopPropagation="false">
                <span>
                    <span class="me-2 text-muted">☰</span>
                    <strong>Round @r.Position</strong>
                    <span class="text-muted me-2">@(AppState.RoundsCollapsed.Contains(r.Id) ? "▶" : "▼")</span>
                    <span class="badge @roundBadge ms-2">@roundLabel</span>
                </span>
                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                    <button class="btn btn-outline-primary btn-sm"
                            @onclick="() => OpenAddSlot(r)">
                        + Slot
                    </button>
                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => RemoveRoundAsync(r.Id)">
                        Remove round
                    </button>
                </div>
            </div>

            @if (!AppState.RoundsCollapsed.Contains(r.Id))
            {
                <div class="list-group list-group-flush">
                    @foreach (var slot in r.Slots.OrderBy(s => s.Position))
                    {
                        var s = slot;
                        var editUrl = s.Question != null
                            ? $"/questions/{s.Question.Id}/edit?returnUrl=/quizzes/{Id}"
                            : null;

                        <div class="list-group-item d-flex align-items-center gap-2"
                             draggable="true"
                             @ondragstart="() => { dragFromSlot = s.Id; dragFromSlotRound = r.Id; }"
                             @ondragover="OnDragOver"
                             @ondragover:preventDefault="true"
                             @ondrop="() => DropSlot(r.Id, s.Id)"
                             style="cursor: grab;">

                            <span class="text-muted flex-shrink-0">☰</span>

                            <span class="badge bg-light text-secondary border flex-shrink-0"
                                  style="min-width: 1.8rem; text-align: center; font-weight: 600;">
                                @s.Position
                            </span>

                            <div style="flex: 1; min-width: 0;">
                                @{
                                    var catColor = s.Category?.ColorHex ?? "#95a5a6";
                                }
                                <CategoryBadge ColorHex="@catColor" Name="@(s.Category?.Name ?? "")"
                                               CssClass="text-truncate d-inline-block"
                                               Style="max-width: 100%;" />
                            </div>

                            <div style="flex: 4; min-width: 0; cursor: pointer;"
                                @onclick="async () => { if (editUrl != null) Nav.NavigateTo(editUrl); else await OpenPickerAsync(s); }"
                                @onclick:stopPropagation="true">
                                <div class="small fw-semibold text-truncate @(s.Question == null ? "text-muted fst-italic" : "")">
                                    @(s.Question?.TextShort ?? "— click to assign —")
                                    @if (s.Question?.MediaType is { } mt && mt != MediaType.None)
                                    {
                                        var icon = mt switch
                                        {
                                            MediaType.Image => "🖼",
                                            MediaType.Audio => "🎵",
                                            MediaType.Video => "🎬",
                                            _ => ""
                                        };
                                        <span class="ms-1 text-muted fs-4" title="@mt.ToString()"> | @icon</span>
                                    }
                                </div>
                            </div>

                            <div style="flex: 3; min-width: 0; cursor: pointer;"
                                @onclick="async () => { if (editUrl != null) Nav.NavigateTo(editUrl); else await OpenPickerAsync(s); }"
                                @onclick:stopPropagation="true">
                                @if (s.Question != null)
                                {
                                    <div class="small text-muted text-truncate">@s.Question.Answer</div>
                                }
                            </div>


                            <div class="d-flex gap-1 flex-shrink-0" @onclick:stopPropagation="true">
                                @if (s.Question != null)
                                {
                                    <button class="btn btn-outline-secondary btn-sm"
                                            title="Reassign question"
                                            @onclick="async () => await OpenPickerAsync(s)"
                                            @onclick:stopPropagation="true">
                                        <span class="oi oi-pencil" />
                                    </button>

                                    <button class="btn btn-outline-secondary btn-sm"
                                            title="Unassign question"
                                            @onclick="() => UnassignAsync(s.Id)">
                                        <span class="oi oi-action-undo" />
                                    </button>
                                }

                                <button class="btn btn-outline-danger btn-sm"
                                        title="Remove slot"
                                        @onclick="() => RemoveSlotAsync(s.Id)">
                                    <span class="oi oi-trash" />
                                </button>
                            </div>

                        </div>

                        @if (pickerSlot?.Id == s.Id)
                        {
                            <div class="list-group-item p-2 border-top bg-light">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-semibold small">Assign question — @pickerSlot.Category?.Name</span>
                                    <button class="btn-close btn-sm" @onclick="() => pickerSlot = null" />
                                </div>
                                <input class="form-control form-control-sm mb-2"
                                       placeholder="Search…"
                                       value="@pickerSearch"
                                       @oninput="e => { pickerSearch = e.Value?.ToString() ?? string.Empty; ApplyFilter(); }" />
                                <div class="small text-muted mb-2">
                                    @pickerFiltered.Count of @pickerAll.Count in this category
                                </div>
                                <div class="list-group">
                                    @foreach (var picker in pickerFiltered.Take(Constants.PageSizePicker))
                                    {
                                        <button class="list-group-item list-group-item-action py-1"
                                                @onclick="() => AssignAsync(picker.Id)">
                                            <div class="small fw-semibold">
                                                @picker.TextShort
                                                @if (picker?.MediaType is { } mts && mts != MediaType.None)
                                                {
                                                    var icon = mts switch
                                                    {
                                                        MediaType.Image => "🖼",
                                                        MediaType.Audio => "🎵",
                                                        MediaType.Video => "🎬",
                                                        _ => ""
                                                    };
                                                    <span class="small text-muted fs-4" title="@mts.ToString()"> | @icon</span>
                                                }
                                            </div>
                                            <div class="small text-muted">→ @picker?.Answer</div>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                @* ── Inline Add Slot ── *@
                @if (addSlotRound?.Id == r.Id)
                {
                    <div class="card-body border-top d-flex gap-2 align-items-center">
                        <select class="form-select" @bind="addSlotCategoryId">
                            <option value="@Guid.Empty">— select category —</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                        <button class="btn btn-success btn-sm text-nowrap"
                                @onclick="ConfirmAddSlotAsync"
                                disabled="@(addSlotCategoryId == Guid.Empty)">
                            Add
                        </button>
                        <button class="btn btn-outline-secondary btn-sm text-nowrap"
                                @onclick="() => addSlotRound = null">
                            Cancel
                        </button>
                    </div>
                }
            }
        </div>
    }

    @* Add round controls *@
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <button class="btn btn-outline-secondary btn-sm"
                @onclick="AddEmptyRoundAsync">
            + Empty round
        </button>
        <button class="btn btn-outline-primary btn-sm"
                @onclick="() => showTemplatePicker = true">
            + Round from template
        </button>
    </div>

    @if (showTemplatePicker)
    {
        <div class="card border-primary mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Add round from template</strong>
                <button class="btn-close" @onclick="() => showTemplatePicker = false" />
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <select class="form-select" @bind="selectedTemplateId">
                    <option value="@Guid.Empty">— select template —</option>
                    @foreach (var t in templates)
                    {
                        <option value="@t.Id">@t.Name (@t.Slots.Count slots)</option>
                    }
                </select>
                <button class="btn btn-primary btn-sm"
                        @onclick="AddRoundFromTemplateAsync"
                        disabled="@(selectedTemplateId == Guid.Empty)">
                    Add round
                </button>
            </div>
        </div>
    }
}
