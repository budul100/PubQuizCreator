@page "/quizzes"
@inject QuizService QuizService
@inject StateService StateService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Quizzes</PageTitle>

<PageHeader Title="Quizzes">
    <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetView(!showCompleted)">
        @(showCompleted ? "Show Active" : "Show Completed")
    </button>
    @if (!showCompleted)
    {
        <button class="btn btn-primary btn-sm" @onclick="() => showCreate = true">+ New quiz</button>
    }
</PageHeader>

@if (showCreate)
{
    <div class="card mb-4">
        <div class="card-body d-flex flex-column gap-2">
            <input class="form-control" placeholder="Title" @bind="newTitle" />
            <input class="form-control" type="date"
                   value="@newDate.ToString("yyyy-MM-dd")"
                   @onchange="e => newDate = DateOnly.Parse(e.Value?.ToString() ?? string.Empty)" />
            <div class="d-flex gap-2">
                <button class="btn btn-primary btn-sm"
                        @onclick="CreateAsync"
                        disabled="@(string.IsNullOrWhiteSpace(newTitle))">
                    Create
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => showCreate = false">Cancel</button>
            </div>
        </div>
    </div>
}

@{
    var displayed = showCompleted 
        ? completed 
        : active;
}

@if (!displayed.Any())
{
    <p class="text-muted">No quizzes.</p>
}
else
{
    <div class="list-group">
        @foreach (var q in displayed)
        {
            var totalSlots = q.Rounds.SelectMany(r => r.Slots).Count();
            var openSlots = q.Rounds.SelectMany(r => r.Slots).Count(s => s.QuestionId == null);

            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                    <a class="d-flex justify-content-between align-items-center flex-grow-1 text-decoration-none text-body"
                       href="/quizzes/@q.Id">
                        <div>
                            <div class="fw-semibold">@q.Title</div>
                            <small class="text-muted">@q.Date.ToString("dd.MM.yyyy")</small>
                        </div>
                    </a>

                    @if (totalSlots == 0)
                    {
                        <div @onclick:stopPropagation="true">
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAsync(q.Id)">
                                <span class="oi oi-trash" />
                            </button>
                        </div>
                    }
                    else
                    {
                        <SlotBadge Open="openSlots" Total="totalSlots" CssClass="me-3" />
                    }
                </div>
            </div>
        }
    </div>
}
