@page "/questions/new"
@page "/questions/{Id:guid}/edit"
@using PubQuizCreator.Core
@using PubQuizCreator.Core.Helpers
@using PubQuizCreator.Core.Models
@using PubQuizCreator.Core.Types
@using PubQuizCreator.Services
@using System.Text.RegularExpressions
@inject IdeaService IdeaService
@inject CategoryService CategoryService
@inject QuestionService QuestionService
@inject MediaService MediaService
@inject StateService StateService
@inject IConfiguration Configuration
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@(IsNew ? "New Question" : "Edit Question")</PageTitle>

<div class="d-flex gap-4 align-items-start mb-5">

    <div style="flex: 1; min-width: 0;">

        @if (ideaText != null)
        {
            <div class="alert alert-secondary mb-3">
                <strong>Original idea:</strong><br />
                @ideaText
            </div>
        }

        @if (model.IsUnusable)
        {
            <div class="alert alert-warning mb-3">
                This question is marked as <strong>unusable</strong> and is excluded from all lists.
            </div>
        }

        <h4 class="mb-3">@(IsNew ? "New Question" : "Edit Question")</h4>

        <EditForm Model="model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Category</label>
                <select class="form-select" value="@(model.CategoryId?.ToString() ?? string.Empty)"
                        @onchange="OnCategoryChanged">
                    <option value="">— select —</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Short text
                    <small class="text-muted">(for presentation)</small>
                </label>
                <textarea class="form-control" rows="2"
                          value="@model.TextShort"
                          @oninput="e => { model.TextShort = e.Value?.ToString() ?? string.Empty; TriggerSimilaritySearch(); }" />
            </div>

            @{
                var shortLen = model.TextShort?.Length ?? 0;

                var warnLength = Configuration.GetValue<int>("Quiz:TextShortWarnLength", Constants.TextShortWarnLength);
                var warnClass = shortLen > warnLength ? "text-danger fw-semibold" : "text-muted";
            }
            <div class="d-flex gap-3 align-items-center mb-3">
                <small class="@warnClass">
                    @if (shortLen > Constants.TextShortWarnLength)
                    {
                        <span>⚠ Too long for presentation — consider shortening.</span>
                    }
                </small>
                <small class="@warnClass">@shortLen / @warnLength chars</small>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Long text
                    <small class="text-muted">(internal / moderator notes)</small>
                </label>
                <textarea class="form-control" rows="5"
                          value="@model.TextLong"
                          @oninput="e => { model.TextLong = e.Value?.ToString() ?? string.Empty; TriggerSimilaritySearch(); }" />
            </div>

            <div class="mb-3">
                <label class="form-label">Answer</label>
                <input class="form-control"
                       value="@model.Answer"
                       @oninput="e => { model.Answer = e.Value?.ToString() ?? string.Empty; TriggerSimilaritySearch(); }" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Media</label>

                @* Preview of currently stored file *@
                @if (!string.IsNullOrEmpty(model.MediaFile))
                {
                    <div class="mb-2">
                        @if (model.MediaType == MediaType.Image)
                        {
                            <img src="@MediaService.GetUrl(model.MediaFile)"
                                 class="img-fluid rounded border"
                                 style="max-height: 220px;" />
                        }
                        else if (model.MediaType == MediaType.Audio)
                        {
                            <audio controls src="@MediaService.GetUrl(model.MediaFile)" class="w-100" />
                        }
                        else if (model.MediaType == MediaType.Video)
                        {
                            <video controls src="@MediaService.GetUrl(model.MediaFile)"
                                   class="img-fluid rounded border"
                                   style="max-height: 220px;" />
                        }
                        <div class="d-flex align-items-center gap-2 mt-2">
                            <small class="text-muted text-truncate" style="max-width: 300px;">@model.MediaFile</small>
                            <button type="button" class="btn btn-outline-danger btn-sm"
                                    @onclick="RemoveMediaAsync">
                                Remove media
                            </button>
                        </div>
                    </div>
                }

                @* File picker *@
                <InputFile OnChange="OnFileSelected"
                           accept="image/*,audio/*,video/*"
                           class="form-control" />
                @if (pendingFile != null)
                {
                    <small class="text-muted">
                        Selected: @pendingFile.Name &nbsp;(@(pendingFile.Size / 1024) KB)
                        — type auto-detected as <strong>@model.MediaType</strong>
                    </small>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mt-4">

                <div class="d-flex gap-2">
                    <a class="btn btn-outline-secondary @(!CanCheck ? "disabled" : "")"
                       href="@($"https://www.google.com/search?q={Uri.EscapeDataString((model.TextShort + " " + model.Answer).Trim())}")"
                       target="_blank"
                       tabindex="@(!CanCheck ? -1 : 0)"
                       aria-disabled="@(!CanCheck)"
                       title="Search on Google">
                        🔍 Google
                    </a>
                    <button class="btn btn-outline-secondary"
                            type="button"
                            disabled="@(!CanCheck)"
                            @onclick="OpenAiPromptAsync"
                            title="Run fact-check prompt in AI">
                        🤖 Ask AI
                    </button>
                </div>

                <div class="d-flex gap-2">
                    @if (!model.IsUnusable)
                    {
                        <button class="btn btn-primary" type="submit" disabled="@(!CanSave || saving)">
                            @(saving ? "Saving…" : "Save question")
                        </button>
                        <a class="btn btn-outline-secondary" href="@(IdeaId.HasValue && IdeaId != Guid.Empty ? "/ideas" : "/questions")">Cancel</a>
                        <button class="btn btn-outline-warning"
                                type="button"
                                disabled="@(string.IsNullOrWhiteSpace(model.TextShort) || saving)"
                                @onclick="MarkAsUnusableAsync"
                                title="Save as unusable — excluded from all lists, but kept for similarity search">
                            ⚠ Mark as unusable
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary"
                                type="button"
                                disabled="@saving"
                                @onclick="MarkAsUsableAsync">
                            ↩ Mark as usable
                        </button>
                        <button class="btn btn-outline-danger"
                                type="button"
                                @onclick="DeleteAndGoBackAsync">
                            Delete
                        </button>
                    }
                </div>

            </div>

            @if (saveError != null)
            {
                <div class="alert alert-danger mt-3">@saveError</div>
            }
        </EditForm>
    </div>

    <div style="width: 300px; flex-shrink: 0; position: sticky; top: 1rem;">

        <SimilarsCard SimilarQuestions="@similarQuestions"
            IsSearching="@searchingEmbedding"
            HasSearched="@hasSearched" />

    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }
    [SupplyParameterFromQuery(Name = "ideaId")] public Guid? IdeaId { get; set; }
    [SupplyParameterFromQuery(Name = "categoryId")] public Guid? PreselectedCategoryId { get; set; }

    private bool IsNew => Id == null;

    private bool isInitialized;
    private bool hasSearched;
    private bool saving;
    private bool searchingEmbedding;
    private string? ideaText;
    private List<Category> categories = [];
    private List<QuestionSimilar> similarQuestions = [];
    private QuestionFormModel model = new();
    private string? saveError;
    private Timer? debounceTimer;
    private IBrowserFile? pendingFile;

    protected override async Task OnInitializedAsync()
    {
        StateService.SetPageTitle(IsNew ? "New Question" : "Edit Question");

        categories = await CategoryService.GetAllAsync();

        if (!IsNew && await QuestionService.GetAsync(Id!.Value) is { } q)
            model = QuestionFormModel.From(q);

        if (PreselectedCategoryId.HasValue && PreselectedCategoryId != Guid.Empty)
            model.CategoryId = PreselectedCategoryId.Value;

        if (IdeaId.HasValue && IdeaId != Guid.Empty)
        {
            var idea = await IdeaService.GetAsync(IdeaId.Value);
            if (idea != null)
            {
                var normalized = Regex.Replace(idea.Text.Trim(), @"\s+", " ");
                var match = Regex.Match(normalized, @"^(.+[!?])\s*(.+)$");
                if (match.Success)
                {
                    model.TextShort = match.Groups[1].Value.Trim();
                    model.Answer = match.Groups[2].Value.Trim();
                }
                else
                {
                    model.TextShort = normalized;
                }
                model.CategoryId = idea.CategoryId;
                ideaText = idea.Text;
            }
        }

        isInitialized = true;
    }

    protected override void OnParametersSet()
    {
        if (!isInitialized) return;

        if (PreselectedCategoryId.HasValue && PreselectedCategoryId != Guid.Empty)
            model.CategoryId = PreselectedCategoryId.Value;
    }

    private void OnCategoryChanged(ChangeEventArgs e) 
        => model.CategoryId = Guid.TryParse(e.Value?.ToString(), out var id) ? id.NullIfEmpty() : null;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        pendingFile = e.File;

        // Auto-detect media type from MIME type
        model.MediaType = e.File.ContentType switch
        {
            var ct when ct.StartsWith("image/") => MediaType.Image,
            var ct when ct.StartsWith("audio/") => MediaType.Audio,
            var ct when ct.StartsWith("video/") => MediaType.Video,
            _ => MediaType.None
        };
    }

    private void TriggerSimilaritySearch()
    {
        debounceTimer?.Dispose();
        debounceTimer = new Timer(async _ =>
        {
            await RunSimilaritySearchAsync();
            await InvokeAsync(StateHasChanged);
        }, null, 800, Timeout.Infinite);
    }

    private async Task RunSimilaritySearchAsync()
    {
        var text = $"{model.TextShort} {model.Answer}".Trim();

        searchingEmbedding = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            similarQuestions = await QuestionService.FindSimilarAsync(text, Id ?? Guid.Empty, topN: 5);
            hasSearched = true;
        }
        catch
        {
            // Ollama unavailable — fail silently
        }
        finally
        {
            searchingEmbedding = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenAiPromptAsync()
    {
        var template = Configuration["Quiz:PromptTemplate"]
            ?? "Category: {category}\nQuestion: {question}\nAnswer: {answer}";
        var categoryName = categories.FirstOrDefault(c => c.Id == model.CategoryId)?.Name ?? "—";
        var prompt = template
            .Replace("{category}", categoryName)
            .Replace("{question}", model.TextShort)
            .Replace("{answer}", model.Answer);

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", prompt);

        var aiUrl = Configuration["Quiz:AiUrl"];
        if (!string.IsNullOrWhiteSpace(aiUrl))
            await JS.InvokeVoidAsync("open", aiUrl, "_blank");
    }

    private bool CanCheck => !string.IsNullOrWhiteSpace(model.TextShort)
        || !string.IsNullOrWhiteSpace(model.Answer);

    private bool CanSave => !string.IsNullOrWhiteSpace(model.TextShort)
        && model.CategoryId.HasValue
        && !string.IsNullOrWhiteSpace(model.Answer);

    private async Task SaveAsync()
    {
        if (!CanSave) return;

        saving = true;
        saveError = null;

        try
        {
            // Upload pending file to disk before persisting metadata
            if (pendingFile != null)
            {
                // Delete old file if being replaced
                if (!string.IsNullOrEmpty(model.MediaFile))
                    MediaService.Delete(model.MediaFile);

                await using var stream = pendingFile.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                model.MediaFile = await MediaService.SaveAsync(stream, pendingFile.Name);
            }

            var question = model.ToQuestion(Id);
            if (IsNew) await QuestionService.CreateAsync(question);
            else await QuestionService.UpdateAsync(question);

            var nextCategoryId = model.CategoryId;
            model = new QuestionFormModel { CategoryId = nextCategoryId };
            similarQuestions = [];
            hasSearched = false;

            if (IdeaId.HasValue && IdeaId != Guid.Empty)
            {
                await IdeaService.MarkProcessedAsync(IdeaId.Value);
                Nav.NavigateTo("/ideas");
            }
            else if (IsNew)
            {
                // Stay on new form, carry category selection over
                var query = nextCategoryId.HasValue ? $"?categoryId={nextCategoryId}" : "";
                Nav.NavigateTo($"/questions/new{query}");
            }
            else
            {
                // Came from Index → back to Index
                Nav.NavigateTo("/questions");
            }
        }
        catch (Exception ex)
        {
            saveError = $"Error: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task MarkAsUnusableAsync()
    {
        var confirmed = await JS.ConfirmAsync(
            "Mark as unusable? The question will be saved and excluded from all lists, " +
            "but kept for duplicate detection.");
        if (!confirmed) return;

        saving = true;
        saveError = null;

        try
        {
            model.IsUnusable = true;
            model.WasUsed = true;

            var question = model.ToQuestion(Id);
            if (IsNew) await QuestionService.CreateAsync(question);
            else await QuestionService.UpdateAsync(question);

            if (IdeaId.HasValue && IdeaId != Guid.Empty)
                await IdeaService.MarkProcessedAsync(IdeaId.Value);

            Nav.NavigateTo("/questions");
        }
        catch (Exception ex)
        {
            model.IsUnusable = false;
            model.WasUsed = false;
            saveError = $"Error: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task MarkAsUsableAsync()
    {
        model.IsUnusable = false;
        model.WasUsed = false;
        // User still needs to fill Category + Answer and save normally
        await Task.CompletedTask;
        StateHasChanged();
    }

    private async Task DeleteAndGoBackAsync()
    {
        var confirmed = await JS.ConfirmDeleteAsync(model.TextShort);
        if (!confirmed) return;

        if (Id.HasValue)
            await QuestionService.DeleteAsync(Id.Value);

        Nav.NavigateTo("/questions");
    }

    private void RemoveMediaAsync()
    {
        if (!string.IsNullOrEmpty(model.MediaFile))
            MediaService.Delete(model.MediaFile);

        model.MediaFile = null;
        model.MediaType = MediaType.None;
        pendingFile = null;
    }

    public void Dispose() => debounceTimer?.Dispose();

    private sealed class QuestionFormModel
    {
        public string TextShort { get; set; } = "";
        public string TextLong { get; set; } = "";
        public string Answer { get; set; } = "";
        public Guid? CategoryId { get; set; }
        public string? MediaFile { get; set; }
        public MediaType MediaType { get; set; } = MediaType.None;
        public bool IsUnusable { get; set; } = false;
        public bool WasUsed { get; set; } = false;

        public static QuestionFormModel From(Question q) => new()
        {
            TextShort = q.TextShort,
            TextLong = q.TextLong,
            Answer = q.Answer,
            CategoryId = q.CategoryId,
            MediaFile = q.MediaFile,
            MediaType = q.MediaType,
            IsUnusable = q.IsUnusable,
            WasUsed = q.WasUsed,
        };

        public Question ToQuestion(Guid? existingId) => new()
        {
            Id = existingId ?? Guid.NewGuid(),
            TextShort = TextShort,
            TextLong = TextLong,
            Answer = Answer,
            CategoryId = CategoryId,
            MediaFile = MediaFile,
            MediaType = MediaType,
            IsUnusable = IsUnusable,
            WasUsed = WasUsed,
        };
    }
}
