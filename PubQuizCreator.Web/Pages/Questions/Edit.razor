@page "/questions/new"
@page "/questions/{Id:guid}/edit"
@using PubQuizCreator.Core
@using PubQuizCreator.Core.Helpers
@using PubQuizCreator.Core.Models
@using PubQuizCreator.Core.Types
@using PubQuizCreator.Services
@using System.Text.RegularExpressions
@inject CategoryService CategoryService
@inject IConfiguration Configuration
@inject IdeaService IdeaService
@inject MediaService MediaService
@inject QuestionService QuestionService
@inject StateService StateService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@(IsNew ? "New Question" : "Edit Question")</PageTitle>

<div class="d-flex gap-4 align-items-start mb-5">

    <div style="flex: 1; min-width: 0;">

        @if (ideaText != null)
        {
            <div class="alert alert-secondary mb-3">
                <strong>Original idea:</strong><br />
                @ideaText
            </div>
        }

        @if (model.IsUnusable)
        {
            <div class="alert alert-warning mb-3">
                This question is marked as <strong>unusable</strong> and is excluded from all lists.
            </div>
        }

        <h4 class="mb-3">@(IsNew ? "New Question" : "Edit Question")</h4>

        <EditForm Model="model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Category</label>
                <select class="form-select" value="@(model.CategoryId?.ToString() ?? string.Empty)"
                        @onchange="OnCategoryChanged">
                    <option value="">— select —</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Short text
                    <small class="text-muted">(for presentation)</small>
                </label>
                <input class="form-control"
                       value="@model.TextShort"
                       @oninput="e => { model.TextShort = e.Value?.ToString() ?? string.Empty; TriggerSimilaritySearch(); }" />
            </div>

            @{
                var shortLen = model.TextShort?.Length ?? 0;

                var warnLength = Configuration.GetValue<int>("Quiz:TextShortWarnLength", Constants.TextShortWarnLength);
                var warnClass = shortLen > warnLength ? "text-danger fw-semibold" : "text-muted";
            }
            <div class="d-flex gap-3 align-items-center mb-3">
                <small class="@warnClass">
                    @if (shortLen > warnLength)
                    {
                        <span>⚠ Too long for presentation — consider shortening.</span>
                    }
                </small>
                <small class="@warnClass">@shortLen / @warnLength chars</small>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Long text
                    <small class="text-muted">(internal / moderator notes)</small>
                </label>
                <textarea class="form-control" rows="5"
                          value="@model.TextLong"
                          @oninput="e => { model.TextLong = e.Value?.ToString() ?? string.Empty; TriggerSimilaritySearch(); }" />
            </div>

            <div class="mb-3">
                <label class="form-label">Answer</label>
                <input class="form-control"
                       value="@model.Answer"
                       @oninput="e => { model.Answer = e.Value?.ToString() ?? string.Empty; TriggerSimilaritySearch(); }" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Media</label>

                @* Preview of currently stored file *@
                @if (!string.IsNullOrEmpty(model.MediaFile))
                {
                    <div class="mb-2">
                        @if (model.MediaType == MediaType.Image)
                        {
                            <img src="@MediaService.GetUrl(model.MediaFile)"
                                 class="img-fluid rounded border"
                                 style="max-height: 220px;" />
                        }
                        else if (model.MediaType == MediaType.Audio)
                        {
                            <audio controls src="@MediaService.GetUrl(model.MediaFile)" class="w-100" />
                        }
                        else if (model.MediaType == MediaType.Video)
                        {
                            <video controls src="@MediaService.GetUrl(model.MediaFile)"
                                   class="img-fluid rounded border"
                                   style="max-height: 220px;" />
                        }
                        <div class="d-flex align-items-center gap-2 mt-2">
                            <small class="text-muted text-truncate" style="max-width: 300px;">@model.MediaFile</small>
                            <button type="button" class="btn btn-outline-danger btn-sm"
                                    @onclick="RemoveMediaAsync">
                                Remove media
                            </button>
                        </div>
                    </div>
                }

                @* File picker *@
                <InputFile OnChange="OnFileSelected"
                           accept="image/*,audio/*,video/*"
                           class="form-control" />
                @if (pendingFile != null)
                {
                    <small class="text-muted">
                        Selected: @pendingFile.Name &nbsp;(@(pendingFile.Size / 1024) KB)
                        — type auto-detected as <strong>@model.MediaType</strong>
                    </small>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mt-4">

                <div class="d-flex gap-2">
                    <a class="btn btn-outline-secondary @(!CanCheck ? "disabled" : "")"
                       href="@($"https://www.google.com/search?q={Uri.EscapeDataString((model.TextShort + " " + model.Answer).Trim())}")"
                       target="_blank"
                       tabindex="@(!CanCheck ? -1 : 0)"
                       aria-disabled="@(!CanCheck)"
                       title="Search on Google">
                        🔍 Google
                    </a>
                    <button class="btn btn-outline-secondary"
                            type="button"
                            disabled="@(!CanCheck)"
                            @onclick="OpenAiPromptAsync"
                            title="Run fact-check prompt in AI">
                        🤖 Ask AI
                    </button>
                </div>

                <div class="d-flex gap-2">
                    @if (!model.IsUnusable)
                    {
                        <button class="btn btn-primary" type="submit" disabled="@(!CanSave || saving)">
                            @(saving ? "Saving…" : "Save question")
                        </button>

                        <a class="btn btn-outline-secondary"
                           href="@(IdeaId.HasValue && IdeaId != Guid.Empty ? "/ideas" : ReturnUrl ?? "/questions")">
                            Cancel
                        </a>

                        <button class="btn btn-outline-warning"
                                type="button"
                                disabled="@(string.IsNullOrWhiteSpace(model.TextShort) || saving)"
                                @onclick="MarkAsUnusableAsync"
                                title="Save as unusable — excluded from all lists, but kept for similarity search">
                            ⚠ Mark as unusable
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary"
                                type="button"
                                disabled="@saving"
                                @onclick="MarkAsUsableAsync">
                            ↩ Mark as usable
                        </button>
                        <button class="btn btn-outline-danger"
                                type="button"
                                @onclick="DeleteAndGoBackAsync">
                            Delete
                        </button>
                    }
                </div>

            </div>

            @if (saveError != null)
            {
                <div class="alert alert-danger mt-3">@saveError</div>
            }
        </EditForm>
    </div>

    <div style="width: 300px; flex-shrink: 0; position: sticky; top: 1rem;">

        <SimilarsCard SimilarQuestions="@similarQuestions"
            IsSearching="@searchingEmbedding"
            HasSearched="@hasSearched" />

    </div>
</div>
