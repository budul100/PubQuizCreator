@page "/questions"
@using PubQuizCreator.Services.StateService
@inject CategoryService CategoryService
@inject MediaService MediaService
@inject QuestionService QuestionService
@inject QuizService QuizService
@inject StateService StateService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Questions</PageTitle>

<div class="d-flex gap-4 align-items-start">

    <div style="flex: 1; min-width: 0;">

        <PageHeader Title="Questions">
            <a class="btn btn-primary btn-sm" href="/questions/new">+ New question</a>
        </PageHeader>

        <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">

            <select 
                class="form-select form-select-sm w-auto"
                value="@GetCategorySelectValue()"
                @onchange="OnCategoryChanged">
                
                <option value="all">All categories</option>
                <option value="allWithHidden">All incl. hidden</option>
                
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name (@countByCategory.GetValueOrDefault(cat.Id, 0))</option>
                }
                
                <option value="unusable">— Unusable —</option>
            </select>

            <div class="form-check mb-0 text-nowrap">
                <input class="form-check-input" type="checkbox"
                       @bind="showUsed"
                       @bind:after="ApplyFilterAsync" />
                <label class="form-check-label small">Include used questions</label>
            </div>

            <UnidirectionalInput 
                Placeholder="Search..."
                ShowClearButton=true
                Value="@searchText"
                ValueChanged="SetSearchAsync" />

        </div>

        @if (isLoading)
        {
            <LoadingSpinner Message="Loading questions…" />
        }
        else
        {
            <div class="mb-2 text-muted small">
                Showing @entries.Count of @totalCount questions
            </div>

            @if (totalCount == 0)
            {
                <p class="text-muted">No questions found.</p>
            }
            else
            {
                @* --- MOBILE: Card list (< md) --- *@
                <div class="d-md-none">
                    @foreach (var entry in entries)
                    {
                        var editUrl = $"/questions/{entry.Question.Id}/edit";
                        var rowStyle = entry.Question.IsUnusable ? "opacity: 0.55;" : "";

                        <div class="list-group-item d-flex flex-column gap-1 py-2"
                             style="cursor: pointer; @rowStyle"
                             @onclick="() => Nav.NavigateTo(editUrl)">

                            <div class="d-flex justify-content-between align-items-start">

                                <CategoryBadge 
                                    Name="@(entry.Question.Category?.Name ?? "")"
                                    IsUnusable="@entry.Question.IsUnusable"
                                    ColorHex="@(entry.Question.Category?.ColorHex ?? "#aaaaaa")" />

                                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                    @if (entry.IsUsed)
                                    {
                                        <ReuseButton 
                                            IsUsed="@entry.IsUsed"
                                            IsUnusable="@entry.Question.IsUnusable"
                                            AllowReuse="@entry.Question.AllowReuse"
                                            OnToggle="v => ToggleReuseAsync(entry.Question.Id, v)" />

                                    }
                                    else
                                    {
                                        <DeleteButton 
                                            IsUsed="@entry.IsUsed"
                                            OnDelete="() => DeleteAsync(entry.Question.Id)" />
                                    }
                                </div>

                            </div>

                            <div class="fw-semibold small">@entry.Question.TextShort</div>
                            <div class="text-muted small">→ @entry.Question.Answer</div>

                            <MediaIcon 
                                MediaType="@entry.Question.MediaType" />

                            <UsageLabel UsedInQuiz="@entry.UsedInQuiz"
                                IsUsed="@entry.IsUsed" />
                        </div>
                    }
                </div>

                @* --- DESKTOP: Table (>= md) --- *@
                <div class="d-none d-md-block table-responsive">
                    <table class="table table-sm table-hover align-middle">

                        <thead>
                            <tr>
                                <th style="width: calc((100% - 250px) / 8)">Category</th>
                                <th style="width: calc((100% - 250px) * 4 / 8)">Question</th>
                                <th style="width: calc((100% - 250px) * 3 / 8)">Answer</th>
                                <th style="width: 200px">Used in</th>
                                <th style="width: 40px"></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var entry in entries)
                            {
                                var editUrl = $"/questions/{entry.Question.Id}/edit";
                                var rowStyle = entry.Question.IsUnusable ? "opacity: 0.55;" : "";

                                <tr style="cursor: pointer; @rowStyle" @onclick="() => Nav.NavigateTo(editUrl)">

                                    <td>
                                        <CategoryBadge 
                                            Name="@(entry.Question.Category?.Name ?? "")"
                                            IsUnusable="@entry.Question.IsUnusable"
                                            ColorHex="@(entry.Question.Category?.ColorHex ?? "#aaaaaa")" />
                                    </td>

                                    <td>
                                        <div style="display: inline;">@entry.Question.TextShort</div><MediaIcon 
                                            MediaType="@entry.Question.MediaType"/>
                                    </td>

                                    <td class="text-muted">@entry.Question.Answer</td>
                                    
                                    <td @onclick:stopPropagation="true">
                                        <UsageLabel 
                                            UsedInQuiz="@entry.UsedInQuiz"
                                            IsUsed="@entry.IsUsed" />
                                    </td>

                                    <td @onclick:stopPropagation="true">
                                        @if (entry.IsUsed)
                                        {
                                            <ReuseButton 
                                                IsUsed="@entry.IsUsed"
                                                IsUnusable="@entry.Question.IsUnusable"
                                                AllowReuse="@entry.Question.AllowReuse"
                                                OnToggle="v => ToggleReuseAsync(entry.Question.Id, v)" />

                                        }
                                        else
                                        {
                                            <DeleteButton 
                                                IsUsed="@entry.IsUsed"
                                                OnDelete="() => DeleteAsync(entry.Question.Id)" />
                                        }
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>

                </div>

                <ContentPager TotalItems="@totalCount"
                              PageSize="@Constants.PageSizeList"
                              CurrentPage="@currentPage"
                              PageChanged="@OnPageChanged" />

            }
        }

    </div>

    <div class="d-none d-md-block" style="width: 300px; flex-shrink: 0; position: sticky; top: 1rem;">
        <CoverageCard NavigateToQuestions="true" />
    </div>

</div>
