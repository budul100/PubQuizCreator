@page "/questions"
@inject CategoryService CategoryService
@inject QuestionService QuestionService
@inject QuizService QuizService
@inject StateService StateService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Questions</PageTitle>

<div class="d-flex gap-4 align-items-start">

    <div style="flex: 1; min-width: 0;">

        <PageHeader Title="Questions">
            <a class="btn btn-primary btn-sm" href="/questions/new">+ New question</a>
        </PageHeader>

        <div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
            <div class="form-check mb-0 text-nowrap">
                <input class="form-check-input" type="checkbox"
                       @bind="showUsed"
                       @bind:after="ApplyFilterAsync" />
                <label class="form-check-label small">Show used</label>
            </div>

            <select 
                class="form-select form-select-sm w-auto"
                value="@GetCategorySelectValue()"
                @onchange="OnCategoryChanged">
                
                <option value="all">All categories</option>
                <option value="allWithHidden">All incl. hidden</option>
                
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name (@countByCategory.GetValueOrDefault(cat.Id, 0))</option>
                }
                
                <option value="unusable">— Unusable —</option>
            </select>

            <SearchInput @bind-Value="searchInput"
                         @bind-Value:after="ApplyFilterAsync" />

        </div>

        @if (isLoading)
        {
            <LoadingSpinner Message="Loading questions…" />
        }
        else
        {
            <div class="mb-2 text-muted small">
                Showing @pageds.Count of @totalCount questions
            </div>

            @if (totalCount == 0)
            {
                <p class="text-muted">No questions found.</p>
            }
            else
            {
                @* --- MOBILE: Card list (< md) --- *@
                <div class="d-md-none">
                    @foreach (var question in pageds)
                    {
                        var editUrl = $"/questions/{question.Id}/edit";
                        var rowStyle = question.IsUnusable ? "opacity: 0.55;" : "";

                        <div class="list-group-item d-flex flex-column gap-1 py-2"
                             style="cursor: pointer; @rowStyle"
                             @onclick="() => Nav.NavigateTo(editUrl)">

                            <div class="d-flex justify-content-between align-items-start">

                                <CategoryBadge 
                                    Name="@(question.Category?.Name ?? "")"
                                    IsUnusable="@question.IsUnusable"
                                    ColorHex="@(question.Category?.ColorHex ?? "#aaaaaa")" />

                                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                    @if (question.IsUsed)
                                    {
                                        <ReuseButton IsUsed="@question.IsUsed"
                                                     IsUnusable="@question.IsUnusable"
                                                     AllowReuse="@question.AllowReuse"
                                                     OnToggle="v => ToggleReuseAsync(question.Id, v)" />

                                    }
                                    else
                                    {
                                        <DeleteButton IsUsed="@question.IsUsed"
                                                      OnDelete="() => DeleteAsync(question.Id)" />
                                    }
                                </div>

                            </div>

                            <div class="fw-semibold small">@question.TextShort</div>
                            <div class="text-muted small">→ @question.Answer</div>

                            <UsageLabel 
                                UsedInQuiz="@question.UsedInQuiz"
                                IsUsed="@question.IsUsed" />
                        </div>
                    }
                </div>

                @* --- DESKTOP: Table (>= md) --- *@
                <div class="d-none d-md-block table-responsive">
                    <table class="table table-sm table-hover align-middle">

                        <thead>
                            <tr>
                                <th style="width: calc((100% - 250px) / 8)">Category</th>
                                <th style="width: calc((100% - 250px) * 4 / 8)">Question</th>
                                <th style="width: calc((100% - 250px) * 3 / 8)">Answer</th>
                                <th style="width: 200px">Used in</th>
                                <th style="width: 40px"></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var question in pageds)
                            {
                                var editUrl = $"/questions/{question.Id}/edit";
                                var rowStyle = question.IsUnusable ? "opacity: 0.55;" : "";

                                <tr style="cursor: pointer; @rowStyle" @onclick="() => Nav.NavigateTo(editUrl)">

                                    <td>
                                        <CategoryBadge 
                                            Name="@(question.Category?.Name ?? "")"
                                            IsUnusable="@question.IsUnusable"
                                            ColorHex="@(question.Category?.ColorHex ?? "#aaaaaa")" />
                                    </td>

                                    <td>
                                        @question.TextShort
                                        <MediaIcon Type="@question.MediaType" Prefix="" />
                                    </td>

                                    <td class="text-muted">@question.Answer</td>
                                    
                                    <td @onclick:stopPropagation="true">
                                        <UsageLabel 
                                            UsedInQuiz="@question.UsedInQuiz"
                                            IsUsed="@question.IsUsed" />
                                    </td>

                                    <td @onclick:stopPropagation="true">
                                        @if (question.IsUsed)
                                        {
                                            <ReuseButton IsUsed="@question.IsUsed"
                                                         IsUnusable="@question.IsUnusable"
                                                         AllowReuse="@question.AllowReuse"
                                                         OnToggle="v => ToggleReuseAsync(question.Id, v)" />

                                        }
                                        else
                                        {
                                            <DeleteButton IsUsed="@question.IsUsed"
                                                          OnDelete="() => DeleteAsync(question.Id)" />
                                        }
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>

                </div>

                <ContentPager TotalItems="@totalCount"
                              PageSize="@Constants.PageSizeList"
                              CurrentPage="@currentPage"
                              PageChanged="@OnPageChanged" />

            }
        }

    </div>

    <div class="d-none d-md-block" style="width: 300px; flex-shrink: 0; position: sticky; top: 1rem;">
        <CoverageCard NavigateToQuestions="true" />
    </div>

</div>
