@page "/questions"
@using Microsoft.EntityFrameworkCore
@using PubQuizCreator.Core.Models
@using PubQuizCreator.Data
@using PubQuizCreator.Services
@inject StateService AppState
@inject QuestionService QuestionService
@inject QuizService QuizService
@inject CategoryService CategoryService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Questions</PageTitle>

<div class="d-flex gap-4 align-items-start">

    <div style="flex: 1; min-width: 0;">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">
                Questions
                @if (totalOpenSlots > 0)
                {
                    <span class="badge bg-warning text-dark ms-2">@totalOpenSlots open</span>
                }
            </h4>
            <a class="btn btn-primary btn-sm" href="/questions/new">+ New question</a>
        </div>

        <div class="d-flex gap-2 mb-3 align-items-center">
            <div class="form-check mb-0 text-nowrap">
                <input class="form-check-input" type="checkbox"
                       @bind="showUsed"
                       @bind:after="ApplyFilterAsync" />
                <label class="form-check-label small">Show useds</label>
            </div>
            <select class="form-select form-select-sm w-auto" @onchange="OnCategoryChanged">
                <option value="@Guid.Empty">All categories</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name (@questionCountByCategory.GetValueOrDefault(cat.Id, 0))</option>
                }
            </select>
            <input class="form-control form-control-sm" placeholder="Search…"
                value="@searchText"
                @oninput="async e => { searchText = e.Value?.ToString() ?? string.Empty; await ApplyFilterAsync(); }" />
        </div>

        @if (isLoading)
        {
            <div class="d-flex align-items-center gap-2 text-muted">
                <div class="spinner-border spinner-border-sm" />
                <span>Loading questions…</span>
            </div>
        }
        else
        {
            <div class="mb-2 text-muted small">
                Showing @filtered.Count of @total questions
            </div>

            @if (!filtered.Any())
            {
                <p class="text-muted">No questions found.</p>
            }
            else
            {
                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: calc((100% - 250px) / 8)">Category</th>
                            <th style="width: calc((100% - 250px) * 4 / 8)">Question</th>
                            <th style="width: calc((100% - 250px) * 3 / 8)">Answer</th>
                            <th style="width: 200px">Used in</th>
                            <th style="width: 50px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in filtered)
                        {
                            var categoryColor = q.Category?.ColorHex ?? "#ffffff";
                            var editUrl = $"/questions/{q.Id}/edit";

                            <tr style="cursor: pointer;" @onclick="() => Nav.NavigateTo(editUrl)">
                                <td>
                                    <span class="badge" style="background-color: @categoryColor; color: @categoryColor.TextColor();">
                                        @q.Category?.Name
                                    </span>
                                </td>
                                <td>@q.TextShort</td>
                                <td class="text-muted">@q.Answer</td>
                                <td>
                                    @if (q.UsedInQuiz != null)
                                    {
                                        <small class="text-muted">@q.UsedInQuiz</small>
                                    }
                                    else if (q.WasUsed)
                                    {
                                        <small class="text-muted fst-italic">previously used</small>
                                    }
                                </td>
                                <td @onclick:stopPropagation="true">
                                    @if (q.UsedInQuiz == null)
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAsync(q.Id)">✕</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }

    </div>

    <div style="width: 300px; flex-shrink: 0; position: sticky; top: 1rem;">
        <CoverageCard />
    </div>

</div>

@code {
    private bool showUsed = false;
    private string searchText = "";

    private List<Category> categories = [];
    private List<QuestionRow> all = [];
    private List<QuestionRow> filtered = [];
    private Dictionary<Guid, int> questionCountByCategory = [];
    private bool isLoading = true;
    private int totalOpenSlots;
    private int total;
    private Guid selectedCategoryId;

    protected override async Task OnInitializedAsync()
    {
        AppState.SetPageTitle("Questions");

        isLoading = true;

        categories = await CategoryService.GetAllAsync();

        var questions = await QuestionService.GetAllAsync();
        var usageMap = await QuestionService.GetUsageMapAsync();
        var usageDateMap = await QuestionService.GetUsageDateMapAsync();

        all = questions.Select(q => new QuestionRow(
            q.Id,
            q.TextShort,
            q.Answer,
            q.Category,
            q.WasUsed,
            usageMap.GetValueOrDefault(q.Id),
            usageDateMap.GetValueOrDefault(q.Id)
        )).ToList();

        total = all.Count;
        totalOpenSlots = await QuizService.GetTotalOpenSlotsAsync();

        questionCountByCategory = all
            .GroupBy(q => q.Category?.Id ?? Guid.Empty)
            .ToDictionary(g => g.Key, g => g.Count());

        await ApplyFilterAsync();

        isLoading = false;
    }

    private async Task OnCategoryChanged(ChangeEventArgs e)
    {
        selectedCategoryId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
        await ApplyFilterAsync();
    }

    private async Task ApplyFilterAsync()
    {
        isLoading = true;
        StateHasChanged();
        await Task.Yield();

        filtered = all
            .Where(q => selectedCategoryId == Guid.Empty || q.Category?.Id == selectedCategoryId)
            .Where(q => showUsed || (q.UsedInQuiz == null && !q.WasUsed))
            .Where(q => string.IsNullOrWhiteSpace(searchText)
                     || q.TextShort.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                     || q.Answer.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .OrderBy(q => q.LastUsedDate.HasValue ? 0 : q.WasUsed ? 1 : 2)
            .ThenByDescending(q => q.LastUsedDate ?? DateOnly.MinValue)
            .ThenBy(q => q.Category?.Name ?? "")
            .ToList();

        isLoading = false;
    }

    private async Task DeleteAsync(Guid id)
    {
        var question = all.First(q => q.Id == id);

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Delete \"{question.TextShort}\"? This cannot be undone.");
        if (!confirmed) return;

        await QuestionService.DeleteAsync(id);

        all.RemoveAll(q => q.Id == id);
        questionCountByCategory = all
            .GroupBy(q => q.Category?.Id ?? Guid.Empty)
            .ToDictionary(g => g.Key, g => g.Count());
        total = all.Count;

        await ApplyFilterAsync();
    }

    private sealed record QuestionRow(Guid Id, string TextShort, string Answer, Category? Category, bool WasUsed, string? UsedInQuiz, DateOnly? LastUsedDate);
}
