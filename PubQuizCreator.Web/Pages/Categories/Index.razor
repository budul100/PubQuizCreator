@page "/categories"
@using PubQuizCreator.Core.Models
@using PubQuizCreator.Services
@inject CategoryService CategoryService
@inject StateService AppState
@inject IJSRuntime JS

<PageTitle>Categories</PageTitle>

<PageHeader Title="Categories">
    <button class="btn btn-primary btn-sm" @onclick="() => showCreate = true">+ New category</button>
</PageHeader>

@if (showCreate)
{
    <div class="card mb-4">
        <div class="card-body d-flex gap-2 align-items-center">
            <input class="form-control" placeholder="Name" @bind="newName" />
            <input type="color" class="form-control form-control-color" @bind="newColor" />
            <button class="btn btn-primary btn-sm text-nowrap"
                    @onclick="CreateAsync"
                    disabled="@(string.IsNullOrWhiteSpace(newName))">
                Add
            </button>
            <button class="btn btn-outline-secondary btn-sm text-nowrap"
                    @onclick="() => showCreate = false">
                Cancel
            </button>
        </div>
    </div>
}

@if (!categories.Any())
{
    <p class="text-muted">No categories yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var cat in categories)
        {
            <div class="list-group-item d-flex align-items-center gap-3">
                <input type="color"
                       class="form-control form-control-color flex-shrink-0"
                       value="@cat.ColorHex"
                       @onchange="e => UpdateColorAsync(cat, e.Value?.ToString() ?? cat.ColorHex)" />
                <input class="form-control"
                       value="@cat.Name"
                       @onchange="e => UpdateNameAsync(cat, e.Value?.ToString() ?? cat.Name)" />

                <div class="form-check form-switch mb-0 flex-shrink-0 d-flex align-items-center gap-2"
                     style="min-width: 160px;">
                    <input class="form-check-input" type="checkbox"
                           checked="@cat.IsHidden"
                           @onchange="e => UpdateHiddenAsync(cat, (bool)(e.Value ?? false))" />
                    <label class="form-check-label small text-muted">Hidden</label>
                </div>

                <CategoryBadge ColorHex="@cat.ColorHex"
                    Name="@($"{questionCounts.GetValueOrDefault(cat.Id, 0)} questions")"
                    Href="@($"/questions?categoryId={cat.Id}&showUsed=true")"
                    Style="min-width: 90px; font-variant-numeric: tabular-nums;" />

                <div class="d-flex gap-2" @onclick:stopPropagation="true">
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAsync(cat.Id)">✕</button>
                </div>
            </div>
        }
    </div>
}

@code {
    private string newName = "";
    private string newColor = "#95a5a6";

    private bool showCreate;
    private List<Category> categories = [];
    private Dictionary<Guid, int> questionCounts = [];

    protected override async Task OnInitializedAsync()
    {
        AppState.SetPageTitle("Categories");
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        categories = await CategoryService.GetAllAsync();
        questionCounts = await CategoryService.GetQuestionCountsAsync();
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(newName)) return;
        await CategoryService.CreateAsync(newName.Trim(), newColor);
        newName = "";
        newColor = "#95a5a6";
        showCreate = false;
        await ReloadAsync();
    }

    private async Task UpdateNameAsync(Category cat, string name)
    {
        if (string.IsNullOrWhiteSpace(name) || name == cat.Name) return;
        cat.Name = name;
        await CategoryService.UpdateAsync(cat.Id, cat.Name, cat.ColorHex, cat.IsHidden);
    }

    private async Task UpdateColorAsync(Category cat, string color)
    {
        cat.ColorHex = color;
        await CategoryService.UpdateAsync(cat.Id, cat.Name, cat.ColorHex, cat.IsHidden);
        await ReloadAsync();
    }

    private async Task UpdateHiddenAsync(Category cat, bool isHidden)
    {
        cat.IsHidden = isHidden;
        await CategoryService.UpdateAsync(cat.Id, cat.Name, cat.ColorHex, cat.IsHidden);
    }

    private async Task DeleteAsync(Guid id)
    {
        var cat = categories.First(c => c.Id == id);

        if (await CategoryService.IsInUseAsync(id))
        {
            await JS.AlertAsync($"\"{cat.Name}\" is in use and cannot be deleted.");
            return;
        }

        var confirmed = await JS.ConfirmDeleteAsync(cat.Name);
        if (!confirmed) return;

        await CategoryService.DeleteAsync(id);
        await ReloadAsync();
    }
}
