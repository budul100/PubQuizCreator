@page "/categories"
@using PubQuizCreator.Services.App
@inject CategoryService CategoryService
@inject StateService AppState
@inject ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Categories</PageTitle>

<PageHeader Title="Categories">
    <button class="btn btn-primary btn-sm" @onclick="() => showCreate = true">+ New category</button>
</PageHeader>

@if (showCreate)
{
    <div class="card mb-4">
        <div class="card-body d-flex gap-2 align-items-center">
            <input class="form-control" placeholder="Name" @bind="newName" />
            <input type="color" class="form-control form-control-color" @bind="newColor" />
            <button class="btn btn-primary btn-sm text-nowrap"
                    @onclick="CreateAsync"
                    disabled="@(string.IsNullOrWhiteSpace(newName))">
                Add
            </button>
            <button class="btn btn-outline-secondary btn-sm text-nowrap"
                    @onclick="() => showCreate = false">
                Cancel
            </button>
        </div>
    </div>
}

@if (!categories.Any())
{
    <p class="text-muted">No categories yet.</p>
}
else
{
    <div class="list-group">
        <div style="display: grid; grid-template-columns: auto 1fr auto auto; gap: 0.75rem; align-items: center;">
            @foreach (var category in categories)
            {
                <input type="color"
                       class="form-control form-control-color"
                       value="@category.ColorHex"
                       @onchange="e => UpdateColorAsync(category, e.Value?.ToString() ?? category.ColorHex)" />

                <input class="form-control"
                       value="@category.Name"
                       @onchange="e => UpdateNameAsync(category, e.Value?.ToString() ?? category.Name)" />

                <div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
                    <input class="form-check-input" type="checkbox"
                           checked="@category.IsHidden"
                           @onchange="e => UpdateHiddenAsync(category, (bool)(e.Value ?? false))" />
                    <label class="form-check-label small text-muted">Hidden</label>
                </div>

                <div @onclick:stopPropagation="true">
                    @if (questionCounts.GetValueOrDefault(category.Id, 0) == 0)
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAsync(category.Id)">
                            <span class="oi oi-trash" />
                        </button>
                    }
                    else
                    {
                        <ColorBadge 
                            ColorHex="@category.ColorHex"
                            Name="@($"{questionCounts.GetValueOrDefault(category.Id, 0)} questions")"
                            Href="@($"/questions?categoryId={category.Id}&showUsed=true")"
                            Style="font-variant-numeric: tabular-nums;" />
                    }
                </div>
            }
        </div>
    </div>
}
