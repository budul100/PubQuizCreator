@page "/"
@inject IdeaService IdeaService
@inject QuestionService QuestionService
@inject QuizService QuizService
@inject StateService StateService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Pub Quiz Creator</PageTitle>

@if (!isLoaded)
{
    <LoadingSpinner />
}
else
{
    <div class="row g-3">

        @* ── Ideas ── *@
        <div class="col-12 col-lg-4">
            <div class="card h-100">

                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                    <span>Available Ideas</span>
                    @if (ideasUnassigned > 0)
                    {
                        <span class="badge bg-warning text-dark" title="Ideas without category">
                            @ideasUnassigned uncategorized
                        </span>
                    }
                </div>

                <div class="card-body p-0">
                    @if (ideas?.Any() != true)
                    {
                        <p class="text-muted p-3 mb-0">No categorized ideas.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <tbody>

                                <TalliesRow Tallies="ideas" />

                            </tbody>
                        </table>
                    }
                </div>

                <div class="card-footer d-flex gap-2">
                    <a class="btn btn-outline-primary btn-sm" href="/ideas">Open ideas</a>
                    <a class="btn btn-primary btn-sm ms-auto" href="/ideas/new">+ Capture idea</a>
                </div>

            </div>
        </div>

        @* ── Questions ── *@
        <div class="col-12 col-lg-4">

            <div class="card h-100">

                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                    <span>Available Questions</span>
                </div>

                <div class="card-body p-0">
                    @if (questions?.Any() != true)
                    {
                        <p class="text-muted p-3 mb-0">No available questions.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <tbody>

                                <TalliesRow Tallies="questions" />

                            </tbody>
                        </table>
                    }
                </div>

                <div class="card-footer">
                    <a class="btn btn-outline-primary btn-sm" href="/questions">Open questions</a>
                </div>

            </div>
        </div>

        @* ── Quizzes ── *@
        <div class="col-12 col-lg-4">

            <div class="card h-100">

                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                    <span>Next Quiz</span>
                </div>
                
                <div class="card-body">
                    @if (nextQuiz == null)
                    {
                        <p class="text-muted mb-0">No upcoming quizzes.</p>
                    }
                    else
                    {
                        <div class="fw-semibold">@nextQuiz.Title</div>
                        <div class="text-muted small mb-3">@nextQuiz.Date.ToString("dd.MM.yyyy")</div>

                        @if (nextTotal == 0)
                        {
                            <span class="badge bg-secondary">No slots yet</span>
                        }
                        else if (nextOpen == 0)
                        {
                            <span class="badge bg-success fs-6">Complete</span>
                        }
                        else
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge bg-warning text-dark fs-6">
                                    @nextOpen open
                                </span>
                                <span class="text-muted small">of @nextTotal slots</span>
                            </div>
                            <div class="progress mb-3" style="height: 8px;">
                                @{
                                    var filled = nextTotal - nextOpen;
                                    var pct = (int)(100.0 * filled / nextTotal);
                                }
                                <div class="progress-bar bg-success"
                                     style="@($"width: {pct}%")"
                                     role="progressbar"
                                     aria-valuenow="@pct"
                                     aria-valuemin="0"
                                     aria-valuemax="100" />
                            </div>
                        }

    

                        @if (nextTallies?.Any() == true)
                        {
                            <TalliesList Tallies="nextTallies"/>
                        }
                    }
                </div>

                <div class="card-footer">
                    @if (nextQuiz == null)
                    {
                        <a class="btn btn-outline-primary btn-sm" href="/quizzes">Open quizzes</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-primary btn-sm"
                           href="/quizzes/@nextQuiz.Id">
                            Open quiz
                        </a>
                    }
                </div>

            </div>
        </div>

    </div>
}
