@page "/templates"
@using PubQuizCreator.Services.StateService
@inject TemplateService TemplateService
@inject StateService AppState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Templates</PageTitle>

<PageHeader Title="Templates">
    <button class="btn btn-primary btn-sm" @onclick="() => showCreate = true">+ New template</button>
</PageHeader>

@if (showCreate)
{
    <div class="card mb-4">
        <div class="card-body d-flex gap-2 align-items-center">
            <input class="form-control" placeholder="Template name" @bind="newName" />
            <button class="btn btn-primary btn-sm text-nowrap"
                    @onclick="CreateAsync"
                    disabled="@(string.IsNullOrWhiteSpace(newName))">
                Create
            </button>
            <button class="btn btn-outline-secondary btn-sm text-nowrap"
                    @onclick="() => { showCreate = false; newName = string.Empty; }">
                Cancel
            </button>
        </div>
    </div>
}

@if (!templates.Any())
{
    <p class="text-muted">No templates yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var t in templates)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center"
                 style="cursor: pointer;"
                 @onclick="@(() => Nav.NavigateTo($"/templates/{t.Id}/edit"))">
                <div>
                    <div class="fw-semibold">@t.Name</div>
                    <small class="text-muted">
                        @t.Slots.Count slots
                        @if (t.Slots.Count == 0)
                        {
                            <span class="badge bg-secondary ms-1">Empty</span>
                        }
                    </small>
                </div>
                <div class="d-flex gap-2" @onclick:stopPropagation="true">
                    <button class="btn btn-outline-secondary btn-sm"
                        title="Duplicate"
                        @onclick="() => DuplicateAsync(t.Id)">
                        <span class="oi oi-fork" />
                    </button>

                    <button 
                        class="btn btn-outline-danger btn-sm"
                        title="Delete"
                        @onclick="() => DeleteAsync(t.Id)">
                        <span class="oi oi-trash" />
                    </button>

                </div>
            </div>
        }
    </div>
}
