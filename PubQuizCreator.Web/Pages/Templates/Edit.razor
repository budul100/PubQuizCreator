@page "/templates/{Id:guid}/edit"
@using PubQuizCreator.Services.StateService
@inject CategoryService CategoryService
@inject TemplateService TemplateService
@inject StateService AppState
@inject NavigationManager Nav

<PageTitle>Edit Template</PageTitle>

@if (template == null)
{
    <p class="text-muted">Loading…</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <input class="form-control form-control-lg w-auto" style="min-width: 260px;"
               value="@template.Name"
               @onchange="e => template.Name = e.Value?.ToString() ?? string.Empty"
               @onblur="SaveNameAsync" />
        <div class="text-muted small">@slots.Count slots</div>
    </div>

    <div class="list-group mb-3" id="slot-list">
        @for (int i = 0; i < slots.Count; i++)
        {
            var slot = slots[i];
            var idx = i;
            <div class="list-group-item d-flex align-items-center gap-3"
                 draggable="true"
                 @ondragstart="() => dragFrom = idx"
                 @ondragover="OnDragOver"
                 @ondragover:preventDefault="true"
                 @ondrop="() => DropSlot(idx)"
                 style="cursor: grab;">
                <span class="text-muted" style="cursor: grab;">☰</span>
                <span class="text-muted small" style="width: 20px;">@(i + 1)</span>
                <select class="form-select form-select-sm"
                        value="@slot.CategoryId"
                        @onchange="e => slot.CategoryId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty">
                    <option value="@Guid.Empty">— select —</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>

                <button class="btn btn-outline-danger btn-sm" @onclick="() => slots.RemoveAt(idx)">
                    <span class="oi oi-trash" />
                </button>

            </div>
        }
    </div>

    <button class="btn btn-outline-primary btn-sm mb-4"
            @onclick="() => slots.Add(new SlotRow())">
        + Add slot
    </button>

    <hr />

    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@saving">
            @(saving ? "Saving…" : "Save")
        </button>
        <a class="btn btn-outline-secondary" href="/templates">Cancel</a>
    </div>

    @if (saveError != null)
    {
        <div class="alert alert-danger mt-3">@saveError</div>
    }
}