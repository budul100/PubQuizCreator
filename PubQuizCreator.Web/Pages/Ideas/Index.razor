@page "/ideas"
@using Microsoft.EntityFrameworkCore
@using PubQuizCreator.Core.Models
@using PubQuizCreator.Core.Helpers
@using PubQuizCreator.Services
@inject IdeaService IdeaService
@inject CategoryService CategoryService
@inject StateService AppState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Ideas</PageTitle>

<div class="d-flex gap-4 align-items-start">

    <div style="flex: 1; min-width: 0;">

        <PageHeader Title="Ideas">
            <TitleSuffix>
                <span class="badge bg-secondary">@ideas.Count open</span>
            </TitleSuffix>
            <ChildContent>
                <a class="btn btn-primary btn-sm" href="/ideas/new">+ New idea</a>
            </ChildContent>
        </PageHeader>

        <div class="d-flex gap-2 mb-3">
            <select class="form-select form-select-sm w-auto"
                    value="@GetCategorySelectValue()"
                    @onchange="OnCategoryChanged">
                <option value="all">All categories</option>
                <option value="uncategorized">— uncategorized —</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
            <input class="form-control form-control-sm" placeholder="Search…"
                   value="@searchText"
                   @oninput="async e => { searchText = e.Value?.ToString() ?? string.Empty; ApplyFilter(); }" />
            <button class="btn btn-outline-secondary btn-sm text-nowrap"
                    @onclick="async () => { sortAscending = !sortAscending; ApplyFilter(); }">
                📅 @(sortAscending ? "↑" : "↓")
            </button>
        </div>

        @if (lastAssignment != null)
        {
            <div class="alert alert-info d-flex align-items-center gap-2 py-2">
                <span>Category assigned.</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="UndoAssignAsync">Undo</button>
            </div>
        }

        @if (isLoading)
        {
            <LoadingSpinner Message="Loading ideas…" />
        }
        else
        {
            <div class="mb-2 text-muted small">Showing @filtered.Count of @ideas.Count</div>

            @if (!filtered.Any())
            {
                <p class="text-muted">No open ideas.</p>
            }
            else
            {
                <div class="list-group">
                    @foreach (var idea in filtered)
                    {
                        var categoryColor = idea.Category?.ColorHex ?? "#ffffff";

                        <div class="list-group-item d-flex align-items-start gap-3 py-2">

                            <div style="width: 130px; flex-shrink: 0;">
                                @if (idea.Category != null)
                                {
                                    <CategoryBadge ColorHex="@categoryColor" Name="@idea.Category.Name"
                                                   CssClass="d-block text-truncate mb-1" />
                                }
                                else
                                {
                                    <select class="form-select form-select-sm mb-1"
                                            @onchange="e => AssignCategoryAsync(idea.Id, e.Value?.ToString())">
                                        <option value="">— assign —</option>
                                        @foreach (var cat in categories)
                                        {
                                            <option value="@cat.Id">@cat.Name</option>
                                        }
                                    </select>
                                }
                                <div class="form-check mb-0">
                                    <input class="form-check-input" type="checkbox"
                                           checked="@idea.IsTimeSensitive"
                                           @onchange="e => ToggleTimeSensitiveAsync(idea.Id, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label small">Time-sensitive</label>
                                </div>
                            </div>

                            <div style="flex: 1; min-width: 0;">
                                <div>@idea.Text</div>
                                <div class="text-muted small mt-1">@idea.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                            </div>

                            <div class="d-flex gap-1 flex-shrink-0">
                                <a class="btn btn-outline-secondary btn-sm"
                                   href="https://www.google.com/search?q=@Uri.EscapeDataString(idea.Text)"
                                   target="_blank"
                                   title="Google this idea">
                                    <span class="oi oi-magnifying-glass" />
                                </a>
                                <a class="btn btn-outline-primary btn-sm"
                                   href="/questions/new?ideaId=@idea.Id"
                                   title="Turn into question">
                                    <span class="oi oi-arrow-right" />
                                </a>
                                <button class="btn btn-outline-danger btn-sm"
                                        title="Delete"
                                        @onclick="() => DeleteAsync(idea.Id)">
                                    <span class="oi oi-trash" />
                                </button>
                            </div>

                        </div>
                    }
                </div>
            }
        }

    </div>

    <div style="width: 300px; flex-shrink: 0; position: sticky; top: 1rem;">
        <CoverageCard OnCategorySelected="OnCoverageFilterAsync" />
    </div>

</div>

@code {
    private string searchText = "";
    private bool sortAscending = false;
    private bool isLoading = true;

    private List<Idea> ideas = [];
    private List<Idea> filtered = [];
    private List<Category> categories = [];

    private enum IdeaCategoryFilter { All, Uncategorized, Specific }
    private IdeaCategoryFilter filterMode = IdeaCategoryFilter.All;
    private Guid? filterCategoryId;

    private (Guid IdeaId, Guid? OldCategoryId)? lastAssignment;
    private Timer? undoTimer;

    protected override async Task OnInitializedAsync()
    {
        AppState.SetPageTitle("Ideas");

        searchText = AppState.IdeasSearchText;
        sortAscending = AppState.IdeasSortAscending;

        var savedId = AppState.IdeasSelectedCategory;
        if (savedId != Guid.Empty)
        {
            filterMode = IdeaCategoryFilter.Specific;
            filterCategoryId = savedId;
        }

        categories = (await CategoryService.GetAllAsync()).Where(c => !c.IsHidden).ToList();
        await ReloadAsync();

        if (filterMode == IdeaCategoryFilter.All && ideas.Any(i => i.CategoryId == null))
            filterMode = IdeaCategoryFilter.Uncategorized;

        ApplyFilter();
    }

    private void OnCoverageFilterAsync(Guid categoryId)
    {
        filterMode = IdeaCategoryFilter.Specific;
        filterCategoryId = categoryId;
        ApplyFilter();
    }

    private void OnCategoryChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        (filterMode, filterCategoryId) = val switch
        {
            "all" => (IdeaCategoryFilter.All, (Guid?)null),
            "uncategorized" => (IdeaCategoryFilter.Uncategorized, null),
            _ => Guid.TryParse(val, out var id)
                                ? (IdeaCategoryFilter.Specific, id)
                                : (IdeaCategoryFilter.All, null)
        };
        ApplyFilter();
    }

    private async Task ReloadAsync()
    {
        isLoading = true;
        ideas = await IdeaService.GetOpenAsync();
        isLoading = false;
        ApplyFilter();
        StateHasChanged();
    }

    private void ApplyFilter()
    {
        SaveFilterState();

        var q = ideas
            .Where(i => filterMode switch
            {
                IdeaCategoryFilter.Uncategorized => i.CategoryId == null,
                IdeaCategoryFilter.Specific => i.CategoryId == filterCategoryId,
                _ => true
            })
            .Where(i => string.IsNullOrWhiteSpace(searchText)
                     || i.Text.Contains(searchText, StringComparison.OrdinalIgnoreCase));

        filtered = sortAscending
            ? q.OrderByDescending(i => i.IsTimeSensitive).ThenBy(i => i.CreatedAt).ToList()
            : q.OrderByDescending(i => i.IsTimeSensitive).ThenByDescending(i => i.CreatedAt).ToList();
    }

    private string GetCategorySelectValue() => filterMode switch
    {
        IdeaCategoryFilter.Uncategorized => "uncategorized",
        IdeaCategoryFilter.Specific => filterCategoryId?.ToString() ?? "all",
        _ => "all"
    };

    private async Task DeleteAsync(Guid id)
    {
        var confirmed = await JS.ConfirmAsync("Delete this idea? This cannot be undone.");
        if (!confirmed) return;

        await IdeaService.DeleteAsync(id);
        await ReloadAsync();
    }

    private async Task AssignCategoryAsync(Guid ideaId, string? categoryIdStr)
    {
        if (!Guid.TryParse(categoryIdStr, out var categoryId)) return;

        var idea = ideas.First(i => i.Id == ideaId);
        lastAssignment = (ideaId, idea.CategoryId);

        await IdeaService.UpdateCategoryAsync(ideaId, categoryId.NullIfEmpty());

        idea.CategoryId = categoryId;
        idea.Category = categories.First(c => c.Id == categoryId);

        ApplyFilter();

        undoTimer?.Dispose();
        undoTimer = new Timer(async _ =>
        {
            lastAssignment = null;
            await InvokeAsync(StateHasChanged);
        }, null, 5000, Timeout.Infinite);
    }

    private async Task UndoAssignAsync()
    {
        if (lastAssignment == null) return;
        var (ideaId, oldCategoryId) = lastAssignment.Value;

        await IdeaService.UpdateCategoryAsync(ideaId, oldCategoryId);

        var idea = ideas.First(i => i.Id == ideaId);
        idea.CategoryId = oldCategoryId;
        idea.Category = oldCategoryId == null ? null : categories.FirstOrDefault(c => c.Id == oldCategoryId);

        lastAssignment = null;
        undoTimer?.Dispose();

        ApplyFilter();
    }

    private async Task ToggleTimeSensitiveAsync(Guid id, bool value)
    {
        await IdeaService.SetTimeSensitiveAsync(id, value);
        var idea = ideas.First(i => i.Id == id);
        idea.IsTimeSensitive = value;
        ApplyFilter();
    }

    private void SaveFilterState()
    {
        AppState.IdeasSearchText = searchText;
        AppState.IdeasSortAscending = sortAscending;
        AppState.IdeasSelectedCategory = filterMode == IdeaCategoryFilter.Specific
            ? filterCategoryId ?? Guid.Empty
            : Guid.Empty;
    }

    public void Dispose() => undoTimer?.Dispose();
}
